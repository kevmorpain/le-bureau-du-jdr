# NuxtHub
NUXT_HUB_PROJECT_KEY=

# Seed admin (POST /api/admin/seed)
SEED_SECRET=

# ─── Auth (nuxt-auth-utils) ──────────────────────────────────────────────────
# Secret de chiffrement des cookies de session (≥ 32 caractères).
# Génération : `openssl rand -hex 32`
NUXT_SESSION_PASSWORD=

# OAuth Discord — https://discord.com/developers/applications
# Redirect URI à enregistrer : <origin>/auth/discord
NUXT_OAUTH_DISCORD_CLIENT_ID=
NUXT_OAUTH_DISCORD_CLIENT_SECRET=

# OAuth Google — https://console.cloud.google.com/apis/credentials
# Redirect URI à enregistrer : <origin>/auth/google
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=
